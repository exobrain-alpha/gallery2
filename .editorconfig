root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css,scss,html,md,mdx,yml,yaml}]
indent_size = 2

[*.rs]
indent_size = 4
max_line_length = 100

[*.md]
trim_trailing_whitespace = false

[Cargo.lock]
indent_size = 4

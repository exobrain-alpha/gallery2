    "signer:generate": "tauri signer generate -w ~/.tauri/gallery2.key",
    "updater:latest": "node scripts/generate-latest.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "lucide-react": "^1.3.0",

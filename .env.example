# 本机发布脚本配置：复制为 .env 使用，.env 不提交到仓库。
# GALLERY_SIGNING_KEY_PATH 必须是绝对路径；不支持相对路径或 ~。
GALLERY_SIGNING_KEY_PATH=/path/to/gallery2.key

# 公开发布产物根地址：打包脚本会自动追加当前应用版本号。
GALLERY_RELEASES_ROOT_URL=https://example.com/gallery/releases

# macOS Apple 代码签名 identity：执行 security find-identity -v -p codesigning 获取。
# APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# macOS notarization 推荐使用 App Store Connect API。
# APPLE_API_ISSUER=<issuer-id>
# APPLE_API_KEY=<key-id>
# APPLE_API_KEY_PATH=/absolute/path/AuthKey_<key-id>.p8

# macOS notarization 也可以使用 Apple ID + app-specific password。
# APPLE_ID=<apple-id-email>
# APPLE_PASSWORD=<app-specific-password>
# APPLE_TEAM_ID=<team-id>
